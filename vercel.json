{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": { "service": "backend" }
    },
    {
      "source": "/assets/(.*)",
      "destination": { "service": "frontend" }
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|ico|css|js|json|woff|woff2|ttf|eot|html)",
      "destination": { "service": "frontend" }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend",
        "path": "/index.html"
      }
    }
  ]
}
